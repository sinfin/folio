div[
  class=class_name
  data=catalogue_tooltip_data
]
  = folio_icon(:message,
               class: "text-danger \
                       f-c-console-notes-catalogue-tooltip__icon \
                       f-c-console-notes-catalogue-tooltip__icon--some-open",
               height: 18,
               top: -1)

  = folio_icon(:message,
               class: "text-danger \
                       f-c-console-notes-catalogue-tooltip__icon \
                       f-c-console-notes-catalogue-tooltip__icon--only-closed",
               height: 18,
               top: -1)

  .f-c-console-notes-catalogue-tooltip__tooltip
    .f-c-console-notes-catalogue-tooltip__tooltip-inner
      - @record.console_notes.each do |note|
        label.f-c-console-notes-catalogue-tooltip__note
          input.f-c-console-notes-catalogue-tooltip__note-input[
            type="checkbox"
            data-id=note.id
            data-url=url_for([:toggle_closed_at, :console, :api, note])
            checked=note.closed_at?
          ]

          .f-c-console-notes-catalogue-tooltip__content.small
            = cstypo note.content

      span.folio-loader.folio-loader--small[
        class="f-c-console-notes-catalogue-tooltip__loader"
      ]
