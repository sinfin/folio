# frozen_string_literal: true

class <%= application_namespace %>::Atom::Images::SingleImage < Folio::Atom::Base
  ATTACHMENTS = %i[cover]

  STRUCTURE = {
    title: :string,
    subtitle: :string,
    content: :richtext,
  }

  ASSOCIATIONS = {}

  validates :cover_placement,
            presence: true

  def self.console_insert_row
    CONSOLE_INSERT_ROWS[:primary]
  end
end
