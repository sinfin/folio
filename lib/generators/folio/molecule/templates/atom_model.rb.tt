# frozen_string_literal: true

class <%= application_namespace %>::Atom::<%= class_name %> < Folio::Atom::Base
  ATTACHMENTS = %i[]

  STRUCTURE = {}

  ASSOCIATIONS = {}

  <%- if options[:cell] -%>
  def self.molecule_cell_name
    "<%= molecule_cell_name %>"
  end
  <%- else -%>
  MOLECULE = true
  <%- end -%>
end
