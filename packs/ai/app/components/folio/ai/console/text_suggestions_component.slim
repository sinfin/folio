.f-ai-c-text-suggestions[
  class=class_name
  data=component_data
]
  .f-ai-c-text-suggestions__panel[
    id=@component_id
    role="region"
    aria-label=t(".panel_title", field: field_label)
    data=stimulus_action(click: "stopPropagation")
  ]
    - if show_close?
      button.f-ai-c-text-suggestions__close[
        type="button"
        aria-label=t(".close")
        data=stimulus_action(click: "close")
      ]
        = folio_icon(:close, height: 16)

    .f-ai-c-text-suggestions__body
      .f-ai-c-text-suggestions__status[
        hidden=status_hidden?
        data=stimulus_target("status")
      ]
        = folio_icon(:alert,
                     height: 16,
                     class: "text-danger flex-shrink-0 flex-grow-0")
        span data=stimulus_target("statusMessage") = status_message

      - if loading?
        .f-ai-c-text-suggestions__suggestions data=stimulus_target("suggestions")
          - loading_suggestions.each do
            .f-ai-c-text-suggestions__suggestion.f-ai-c-text-suggestions__suggestion--loading
              span.f-ai-c-text-suggestions__suggestion-body
                span.f-ai-c-text-suggestions__suggestion-text = t(".loading")

              span.f-ai-c-text-suggestions__suggestion-actions
                span.f-ai-c-text-suggestions__suggestion-loader-wrap
                  span[
                    class="f-ai-c-text-suggestions__suggestion-loader"
                    class="folio-loader"
                    class="folio-loader--tiny"
                    class="folio-loader--transparent"
                  ]

      - elsif successful?
        .f-ai-c-text-suggestions__suggestions data=stimulus_target("suggestions")
          - @suggestions.each do |suggestion|
            .f-ai-c-text-suggestions__suggestion[
              role="button"
              tabindex="0"
              data=suggestion_data(suggestion)
            ]
              span.f-ai-c-text-suggestions__suggestion-body
                span.f-ai-c-text-suggestions__suggestion-text = suggestion[:text]

              span.f-ai-c-text-suggestions__suggestion-actions
                span.f-ai-c-text-suggestions__suggestion-copy-wrap data=stimulus_action(click: "stopPropagation")
                  = render(Folio::Console::Ui::ClipboardComponent.new(text: suggestion[:text],
                                                                      class_name: "f-ai-c-text-suggestions__suggestion-copy",
                                                                      icon_height: 16))

                button.f-ai-c-text-suggestions__suggestion-accept[
                  type="button"
                  aria-label=t(".accept")
                  title=t(".accept")
                  data=accept_suggestion_data(suggestion)
                ]
                  = folio_icon(:check, height: 16)

      - if show_instructions?
        .f-ai-c-text-suggestions__instructions
          textarea.f-ai-c-text-suggestions__instructions-input.align-self-stretch[
            class="form-control"
            rows="2"
            placeholder=t(".instructions_placeholder")
            data=instructions_data
          ]
            = @instructions

          button.f-ai-c-text-suggestions__regenerate[
            type="button"
            class="btn btn-sm btn-medium-dark"
            data=stimulus_action(click: "regenerate")
          ]
            = t(".regenerate")
