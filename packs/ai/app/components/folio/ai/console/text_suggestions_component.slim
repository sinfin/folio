div[
  id=html_id
  class=bem_class_name
  class=@class_name
  class=("f-ai-c-text-suggestions--external-controls" if external_controls?)
  data=data
]
  - unless external_controls?
    = render(actions_component)

  .f-ai-c-text-suggestions__panel[
    hidden=true
    role="region"
    aria-label=panel_title
    data=stimulus_target("panel")
    data-action="click->f-ai-c-text-suggestions#stopPropagation"
  ]
    .f-ai-c-text-suggestions__header
      .f-ai-c-text-suggestions__title = panel_title
      button.f-ai-c-text-suggestions__close[
        type="button"
        aria-label=t(".close_label")
        data-action="click->f-ai-c-text-suggestions#close"
      ] ×

    .f-ai-c-text-suggestions__status[
      hidden=true
      data=stimulus_target("status")
    ]

    .f-ai-c-text-suggestions__suggestions[
      data=stimulus_target("suggestions")
    ]

    .f-ai-c-text-suggestions__instructions
      textarea.f-ai-c-text-suggestions__instructions-input[
        rows="2"
        placeholder=t(".instructions_placeholder")
        data=stimulus_target("instructions")
      ] = @user_instructions

      button.f-ai-c-text-suggestions__regenerate[
        type="button"
        data-action="click->f-ai-c-text-suggestions#regenerate"
      ]
        = t(".regenerate_label")
